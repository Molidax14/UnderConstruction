[Unit]
Description=Under Construction API (Spring Boot)
After=network.target mariadb.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/underconstruction
EnvironmentFile=/home/ubuntu/underconstruction/.env
ExecStart=/usr/bin/java -jar /home/ubuntu/underconstruction/backend-spring/target/api-0.0.1-SNAPSHOT.jar
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
